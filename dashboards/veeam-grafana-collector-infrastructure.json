          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"veeam_proxy\")\n  |> filter(fn: (r) => r._field == \"enabled\" or r._field == \"max_tasks\")\n  |> filter(fn: (r) => r.customer =~ /^${customer:regex}$/ and r.site =~ /^${site:regex}$/ and r.server =~ /^${server:regex}$/)\n  |> group(columns:[\"proxy\", \"_field\"])\n  |> last()\n  |> group(columns:[\"proxy\"])\n  |> pivot(rowKey:[\"proxy\"], columnKey:[\"_field\"], valueColumn:\"_value\")\n  |> group()\n  |> keep(columns:[\"proxy\", \"enabled\", \"max_tasks\"])"
        }
