        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"veeam_vm_inventory\")\n  |> filter(fn: (r) => r._field == \"present\")\n  |> filter(fn: (r) => r.customer =~ /^${customer:regex}$/ and r.site =~ /^${site:regex}$/ and r.server =~ /^${server:regex}$/ and (r.vm =~ /^${vm:regex}$/))\n  |> group(columns:[\"vm\", \"platform\", \"cluster\", \"host\", \"folder\", \"datastore\", \"power_state\", \"_field\"])\n  |> last()\n  |> group(columns:[\"vm\", \"platform\", \"cluster\", \"host\", \"folder\", \"datastore\", \"power_state\"])\n  |> pivot(rowKey:[\"vm\", \"platform\", \"cluster\", \"host\", \"folder\", \"datastore\", \"power_state\"], columnKey:[\"_field\"], valueColumn:\"_value\")\n  |> keep(columns:[\"vm\", \"platform\", \"cluster\", \"host\", \"folder\", \"datastore\", \"power_state\", \"present\"])"
        }
      ]
    },
