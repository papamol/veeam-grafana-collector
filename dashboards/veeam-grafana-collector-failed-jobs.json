      }
    },
    {
      "id": 1,
      "type": "table",
      "title": "Failed Jobs and VM Tasks",
      "description": "Failed VM task sessions including failure message and duration.",
      "datasource": {
        "type": "influxdb",
        "uid": "$datasource"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "vm"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open VM Drilldown",
                    "url": "/d/veeam-grafana-collector-vm/veeam-grafana-collector-vm?${__url_time_range}&var-datasource=${datasource}&var-bucket=${bucket}&var-customer=${customer}&var-site=${site}&var-server=${server}&var-vm=${__value.raw}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "lg",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"veeam_vm_task_session\")\n  |> filter(fn: (r) => r._field == \"duration_seconds\" or r._field == \"failure_message\")\n  |> filter(fn: (r) => r.customer =~ /^${customer:regex}$/ and r.site =~ /^${site:regex}$/ and r.server =~ /^${server:regex}$/)\n  |> group(columns:[\"job_name\", \"job_category\", \"vm\", \"result\", \"status\", \"_field\"])\n  |> last()\n  |> group(columns:[\"job_name\", \"job_category\", \"vm\", \"result\", \"status\"])\n  |> pivot(rowKey:[\"job_name\", \"job_category\", \"vm\", \"result\", \"status\"], columnKey:[\"_field\"], valueColumn:\"_value\")\n  |> group()\n  |> keep(columns:[\"job_name\", \"job_category\", \"vm\", \"result\", \"status\", \"duration_seconds\", \"failure_message\"])\n  |> filter(fn: (r) => r.result =~ /Failed|Error/ or r.status =~ /Failed|Error/ or (exists r.failure_message and r.failure_message != \"\"))"
        }
      ]
    }
  ],
