      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"${bucket}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"veeam_endpoint_status\")\n  |> filter(fn: (r) => r._field == \"available\" or r._field == \"item_count\" or r._field == \"duration_ms\" or r._field == \"error\")\n  |> filter(fn: (r) => r.customer =~ /^${customer:regex}$/ and r.site =~ /^${site:regex}$/ and r.server =~ /^${server:regex}$/ and (r.collector =~ /tape/))\n  |> group(columns:[\"collector\", \"endpoint\", \"status\", \"_field\"])\n  |> last()\n  |> group(columns:[\"collector\", \"endpoint\", \"status\"])\n  |> pivot(rowKey:[\"collector\", \"endpoint\", \"status\"], columnKey:[\"_field\"], valueColumn:\"_value\")\n  |> keep(columns:[\"collector\", \"endpoint\", \"status\", \"available\", \"item_count\", \"duration_ms\", \"error\"])"
        }
      ]
    }
